# Server Configuration
PORT=3001

# JWT secret (required!) — generate with: openssl rand -hex 32
JWT_SECRET=

# Database (optional — without MongoDB auth and settings persistence are disabled)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=sclr

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Binance API endpoints
BINANCE_WS_URL=wss://fstream.binance.com/ws
BINANCE_REST_URL=https://fapi.binance.com

# Symbol management
# Top N symbols by 24h volume from Binance Futures
TOP_SYMBOLS_COUNT=20
SYMBOL_REFRESH_INTERVAL_MS=3600000

# WebSocket reconnect settings
WS_MAX_RECONNECT_ATTEMPTS=10
WS_INITIAL_RECONNECT_DELAY_MS=1000
WS_MAX_RECONNECT_DELAY_MS=30000

# Logging
LOG_LEVEL=info
